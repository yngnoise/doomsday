# Backend (required)
APP_ENV=development
DATABASE_URL=postgres://postgres:CHANGE_ME@localhost:5432/doomsday
REDIS_URL=localhost:6379
JWT_SECRET=generate-a-random-secret-with-at-least-32-characters
PAYMENT_WEBHOOK_SECRET=generate-a-different-random-secret-with-at-least-32-characters
ADMIN_PASSWORD=generate-a-random-password-with-at-least-16-characters
PORT=8080
SITE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Observability
LOG_LEVEL=info
OTEL_SERVICE_NAME=doomsday-api
# Optional OTLP/HTTP collector endpoint, for example http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# SMTP (optional in demo/test; OTP codes are never written to logs)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Frontend
API_ORIGIN=http://localhost:8080
NEXT_PUBLIC_DROP_ID=dmsdy-ss25-001

# Safe public demo only. Never enable against a production database or Redis.
DEMO_MODE=false
DEMO_OTP_CODE=
DEMO_RESET_ON_START=false

# End-to-end tests only (requires APP_ENV=test)
E2E_OTP_CODE=
